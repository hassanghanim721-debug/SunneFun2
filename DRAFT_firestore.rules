rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'balance', 'createdAt', 'updatedAt']) 
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() < 100
        && data.email is string && data.email.size() < 200
        && data.balance is number && data.balance >= 0
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidInvestment(data) {
      return data.keys().hasAll(['userId', 'name', 'amount', 'profit', 'status', 'routeId', 'createdAt', 'updatedAt'])
        && data.keys().size() == 8
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() < 100
        && data.amount is number && data.amount >= 0
        && data.profit is number
        && data.status in ['Preparing', 'En route', 'Nearing Port', 'Completed', 'Delayed']
        && data.routeId is string
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['ownerId', 'name', 'type', 'category', 'price', 'purchasedAt'])
        && data.keys().size() == 6
        && data.ownerId == request.auth.uid
        && data.name is string && data.name.size() < 100
        && data.type in ['house', 'ship', 'caravan']
        && data.category is string
        && data.price is number && data.price >= 0
        && data.purchasedAt == request.time;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) 
        && isValidUser(incoming()) 
        && incoming().createdAt == existing().createdAt
        && incoming().email == existing().email
        && (
          // Action: Transaction (Updating balance)
          (incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'updatedAt', 'name']))
        );
    }

    match /investments/{investmentId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(investmentId) && isValidInvestment(incoming());
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid 
        && isValidInvestment(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().userId == existing().userId
        && (
          // Action: Status Update
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'profit', 'updatedAt']))
        );
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /properties/{propertyId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(propertyId) && isValidProperty(incoming());
      allow update: if isSignedIn() 
        && resource.data.ownerId == request.auth.uid 
        && incoming().ownerId == existing().ownerId
        && isValidProperty(incoming())
        && (
          // Action: Rename or Maintenance (Simulated)
          (incoming().diff(existing()).affectedKeys().hasOnly(['name']))
        );
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
  }
}
