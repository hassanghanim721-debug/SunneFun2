rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'hassanghanim721@gmail.com';
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      let keys = data.keys();
      return keys.hasAll(['name', 'email', 'balance', 'createdAt', 'updatedAt']) 
        && data.name is string && data.name.size() > 0 && data.name.size() < 100
        && data.email is string && data.email.size() < 200
        && data.balance is number
        && (data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt))
        && data.updatedAt == request.time
        && (!keys.contains('rentCollectionsCount') || data.rentCollectionsCount is number);
    }

    function isValidInvestment(data) {
      let keys = data.keys();
      return keys.hasAll(['userId', 'name', 'amount', 'profit', 'status', 'routeId', 'startTime', 'expiresAt', 'createdAt', 'updatedAt'])
        && keys.size() == 10
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() < 100
        && data.amount is number && data.amount >= 0
        && data.profit is number
        && data.status in ['Preparing', 'En route', 'Nearing Port', 'Completed', 'Delayed']
        && data.routeId is string
        && data.startTime is number
        && data.expiresAt is number
        && (data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt))
        && data.updatedAt == request.time;
    }

    function isValidProperty(data) {
      let keys = data.keys();
      return keys.hasAll(['ownerId', 'name', 'price', 'purchasedAt'])
        && data.ownerId == request.auth.uid
        && data.name is string && data.name.size() < 100
        && (!keys.contains('type') || data.type in ['house', 'ship', 'caravan'])
        && (!keys.contains('category') || data.category is string)
        && data.price is number && data.price >= 0
        && (data.purchasedAt is timestamp || data.purchasedAt is string)
        && (!keys.contains('itemId') || data.itemId is string)
        && (!keys.contains('lastRentCollectedAt') || (data.lastRentCollectedAt is timestamp || data.lastRentCollectedAt is string));
    }

    function isValidTradeLog(data) {
      return data.keys().hasAll(['userId', 'userName', 'routeName', 'amount', 'type', 'timestamp'])
        && data.userId == request.auth.uid
        && data.type in ['start', 'completion', 'sell', 'rent', 'purchase']
        && data.amount is number;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if ((isSignedIn() && request.auth.uid == userId) || isAdmin())
        && isValidUser(incoming()) 
        && (isAdmin() || incoming().createdAt == (existing() == null ? incoming().createdAt : existing().createdAt))
        && (isAdmin() || incoming().email == (existing() == null ? incoming().email : existing().email))
        && (
          isAdmin() || (incoming().diff(existing()).affectedKeys().hasAll(['updatedAt']) && incoming().diff(existing()).affectedKeys().hasAny(['balance', 'updatedAt', 'name', 'rentCollectionsCount']))
        );
    }

    match /investments/{investmentId} {
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() && isValidId(investmentId) && isValidInvestment(incoming());
      allow update: if isSignedIn() 
        && resource.data.userId == request.auth.uid 
        && isValidInvestment(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().userId == existing().userId
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'profit', 'updatedAt']))
        );
      allow delete: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /properties/{propertyId} {
      allow list: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow get: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
      allow create: if isSignedIn() 
        && isValidProperty(incoming())
        && (incoming().purchasedAt == request.time || incoming().purchasedAt is string)
        && (!incoming().keys().contains('lastRentCollectedAt') || (incoming().lastRentCollectedAt == request.time || incoming().lastRentCollectedAt is string));
      allow update: if isSignedIn() 
        && resource.data.ownerId == request.auth.uid 
        && incoming().ownerId == existing().ownerId
        && isValidProperty(incoming())
        && (incoming().purchasedAt == existing().purchasedAt || incoming().purchasedAt is timestamp || incoming().purchasedAt is string)
        && (
          (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'lastRentCollectedAt']))
        );
      allow delete: if (isSignedIn() && resource.data.ownerId == request.auth.uid) || isAdmin();
    }

    match /tradeLogs/{logId} {
      allow create: if isSignedIn() && isValidTradeLog(incoming());
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow get: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /globalState/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && docId == 'propertyStats';
    }
  }
}
