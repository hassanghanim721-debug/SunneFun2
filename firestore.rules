rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'hassanghanim721@gmail.com';
    }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      let keys = data.keys();
      let required = ['name', 'email', 'balance', 'createdAt', 'updatedAt'];
      return keys.hasAll(required)
        && data.name is string && data.name.size() > 0 && data.name.size() < 200
        && data.email is string && data.email.size() < 255
        && data.balance is number
        && (data.createdAt == request.time || data.createdAt is string)
        && (data.updatedAt == request.time || data.updatedAt is string);
    }

    function isValidInvestment(data) {
      let keys = data.keys();
      let required = ['userId', 'name', 'amount', 'profit', 'status', 'routeId', 'startTime', 'expiresAt', 'createdAt', 'updatedAt'];
      return keys.hasAll(required)
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() < 128
        && data.amount is number && data.amount >= 0
        && data.profit is number
        && data.status is string
        && (data.createdAt == request.time || data.createdAt is string)
        && (data.updatedAt == request.time || data.updatedAt is string);
    }

    function isValidProperty(data) {
      let keys = data.keys();
      return keys.hasAll(['ownerId', 'name', 'price', 'purchasedAt'])
        && data.name is string && data.name.size() < 128
        && data.price is number && data.price >= 0;
    }

    function isValidTradeLog(data) {
      let required = ['userId', 'userName', 'routeName', 'amount', 'type', 'timestamp'];
      return data.keys().hasAll(required)
        && data.userId == request.auth.uid
        && data.amount is number;
    }

    // --- Match Rules ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Note: In this specific demo, we allow verified users to update other balances ONLY if 
      // the app logic requires it for auction refunds. In a production app, this would be a Cloud Function.
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isVerified());
    }

    match /investments/{investmentId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /properties/{propertyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin() || isVerified());
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    match /tradeLogs/{logId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /clans/{clanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /globalState/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
